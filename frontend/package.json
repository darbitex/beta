{
  "name": "darbitex-beta-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "snapshot": "npx -y tsx scripts/generate-pool-snapshot.ts",
    "build": "npm run snapshot && tsc -b && vite build",
    "build:skip-snapshot": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^6.3.1",
    "@aptos-labs/wallet-adapter-react": "^8.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
